    <script type="text/javascript">
        $(document).ready(function () {

            $("select").change(function () {
                $(this).removeClass("place-holder");
            });
            var allWells = $('.setup-content'),
                allNextBtn = $('.nextBtn');

            allWells.hide();
            allWells.first().show();

            allNextBtn.click(function () {
                var curStep = $(this).closest(".setup-content"),
                    curInputs = curStep.find("input[type='text'],input[type='url'],input[type='date'], select"),
                    isValid = true;

                $(".form-group").removeClass("has-error");
                for (var i = 0; i < curInputs.length; i++) {
                    if (!curInputs[i].validity.valid) {
                        isValid = false;
                        $(curInputs[i]).addClass("is-invalid");
                    }
                    else
                        $(curInputs[i]).addClass("is-valid");
                }

                if (isValid) {
                    var target = $(this).data('target')
                    if (target) {
                        var $target = $('#' + target);
                        allWells.hide();
                        $target.show();
                        $target.find('input:eq(0)').focus();
                    }
                }
                else {
                    return false;
                }
            });


        });
    </script>


    <script>
        $(document).ready(function () {
            var notification = $('#Notification').val()
            if (notification) {
                var message = JSON.parse(notification)
                $.notify(message.Message, message.TypeString);
            }

            $(".main-menu-icon").click(function (event) {
                $(".user-menu").removeClass("show");
            });
            $(".login-photo.avatar").click(function (event) {
                $(".main-menu").removeClass("show");
            });
            $('#feedbacksend').click(function () {
                var isvalid = $('#formfeedback').validate()
                if (!$('#formfeedback').valid())
                    return false;


                var model = {
                    name: $('#feedbackname').val(),
                    email: $('#feedbackemail').val(),
                    message: $('#feedbackmessage').val(),
                }
                $.ajax({
                    url: '/home/feedback',
                    type: 'post',
                    dataType: 'application/json',
                    data: JSON.stringify(model),
                    contentType: "application/json",
                    dataType: "json",
                    success: function (result) {
                        if (result.code == 0) {
                            $.notify("Thank you for your feedback!", "success");
                            $('#feedbackname').val('')
                            $('#feedbackemail').val('')
                            $('#feedbackmessage').val('')
                        } else {
                            $.notify(result.description, "error");
                        }
                    },
                    failure: function () {
                        $.notify(result.description, "error");
                    }
                });

                return false;
            })

            $('.menu-item').mouseenter(function () {
                $(this).addClass('active2')
            })
            $('.menu-item').mouseleave(function () {
                $(this).removeClass('active2')
            })

            $('.currency-select').change(function () {
                var currency = this.value
                var expires = new Date();
                expires.setTime(expires.getTime() + (365 * 24 * 60 * 60 * 1000));
                document.cookie = 'currency=' + currency + ';path=/' + ';expires=' + expires.toUTCString();

                location.reload();
            })
        })
    </script>


    
